# SmartHealth — Staging Environment
# Deploy: Supabase Cloud staging project OR self-hosted staging stack

APP_NAME=SmartHealth
APP_ENV=staging
SITE_URL=https://staging.smarthealth.co.zw

SUPABASE_PROJECT_ID=smarthealth-staging
SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

JWT_SECRET=

POSTGRES_HOST=db.YOUR_STAGING_PROJECT.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_STAGING_PROJECT.supabase.co:5432/postgres

SMTP_ADMIN_EMAIL=noreply@staging.smarthealth.co.zw
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
SMTP_SENDER_NAME=SmartHealth Staging

AUTH_SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGE_SERVICE_SID=

AUTH_JWT_EXPIRY=3600
AUTH_REFRESH_TOKEN_ROTATION=true

STORAGE_BACKEND=s3
S3_HOST=
S3_REGION=af-south-1
S3_BUCKET=smarthealth-staging-storage
S3_ACCESS_KEY=
S3_SECRET_KEY=

REALTIME_ENABLED=true

BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=14
BACKUP_S3_BUCKET=smarthealth-staging-backups

LOG_LEVEL=info
SENTRY_DSN=
