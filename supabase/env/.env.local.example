# Phone OTP test numbers (see supabase/config.toml [auth.sms.test_otp])
# +263771234567 → 123456
# +263771111111 → 654321

AUTH_SMS_PROVIDER=test
AUTH_JWT_EXPIRY=3600
AUTH_REFRESH_TOKEN_ROTATION=true

STORAGE_BACKEND=file
REALTIME_ENABLED=true

BACKUP_ENABLED=false
LOG_LEVEL=debug

# Flutter app — add to dart-define or .env
# flutter run --dart-define=SUPABASE_URL=$SUPABASE_URL --dart-define=SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
