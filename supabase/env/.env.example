# SmartHealth Supabase — Environment Variables
# Copy the appropriate file for your environment:
#   cp supabase/env/.env.local.example .env.local
#   cp supabase/env/.env.staging.example .env.staging
#   cp supabase/env/.env.production.example .env.production

# Never commit files containing real secrets.

# =============================================================================
# SHARED (all environments)
# =============================================================================

# Application
APP_NAME=SmartHealth
APP_ENV=local                    # local | staging | production
SITE_URL=http://127.0.0.1:3000   # Auth redirect base URL

# Supabase project
SUPABASE_PROJECT_ID=smarthealth-shep

# JWT (must match Supabase Auth settings)
# Local: auto-generated by `supabase start` — see `supabase status`
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters

# =============================================================================
# SUPABASE API (Flutter / web clients)
# =============================================================================

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# DATABASE (direct PostgreSQL — migrations, backups, admin)
# =============================================================================

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=54322
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# =============================================================================
# AUTH
# =============================================================================

# Email (local uses Inbucket — http://127.0.0.1:54324)
SMTP_ADMIN_EMAIL=admin@smarthealth.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=SmartHealth

# Phone OTP — Zimbabwe (+263)
# Production: configure Twilio, MessageBird, or Africa's Talking
AUTH_SMS_PROVIDER=twilio         # twilio | messagebird | africas_talking
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGE_SERVICE_SID=

# Session
AUTH_JWT_EXPIRY=3600             # seconds (1 hour)
AUTH_REFRESH_TOKEN_ROTATION=true

# =============================================================================
# STORAGE
# =============================================================================

STORAGE_BACKEND=file             # file (local) | s3 (self-host/production)
S3_HOST=
S3_REGION=af-south-1             # AWS Cape Town — closest to Zimbabwe
S3_BUCKET=smarthealth-storage
S3_ACCESS_KEY=
S3_SECRET_KEY=

# =============================================================================
# REALTIME
# =============================================================================

REALTIME_ENABLED=true

# =============================================================================
# BACKUPS
# =============================================================================

BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"      # Daily at 02:00 Africa/Harare
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=smarthealth-backups

# =============================================================================
# MONITORING (optional)
# =============================================================================

LOG_LEVEL=info
SENTRY_DSN=
