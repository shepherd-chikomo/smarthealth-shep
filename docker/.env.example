# SmartHealth — unified Docker environment
# Copy to .env in the repository root: cp docker/.env.example .env

# ── General ──────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=smarthealth
ENVIRONMENT=local
PUBLIC_URL=http://localhost
API_PORT=3000

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Supabase / JWT (local demo keys — replace in production) ─────────────────
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
SITE_URL=http://localhost
SUPABASE_PUBLIC_URL=http://localhost:8000

# ── API secrets ──────────────────────────────────────────────────────────────
PAYMENTS_WEBHOOK_SECRET=dev-webhook-secret-change-me
NOTIFICATION_DISPATCH_SECRET=dev-notification-dispatch-secret
ANALYTICS_REFRESH_SECRET=dev-analytics-refresh-secret
FIELD_ENCRYPTION_KEY=local-field-encryption-key-32chars!!
METRICS_TOKEN=local-metrics-scrape-token-uat
RATE_LIMIT_MAX=100

# ── Frontend build args ────────────────────────────────────────────────────────
VITE_API_BASE=/v1
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=${ANON_KEY}

# ── Auth email OTP (GoTrue SMTP — never commit real passwords) ───────────────
# Local dev: Inbucket (http://localhost:54324). Leave USER/PASS empty for plain SMTP.
SMTP_HOST=inbucket
SMTP_PORT=2500
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=noreply@smarthealth.co.zw
SMTP_SENDER_NAME=SmartHealth
# Production example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_PASS=<app-password>

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis-local-password

# ── Backups ──────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *
# S3-compatible object storage (optional — leave blank for local-only backups)
S3_ENDPOINT=
S3_REGION=af-south-1
S3_BUCKET=smarthealth-backups
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Monitoring ─────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
SENTRY_DSN=
UPTIME_KUMA_PORT=3002

# ── SSL (production — used by deploy scripts) ─────────────────────────────────
DOMAIN=localhost
ACME_EMAIL=ops@smarthealth.co.zw
SSL_MODE=self-signed

# ── Studio ───────────────────────────────────────────────────────────────────
STUDIO_PORT=54323
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=supabase
