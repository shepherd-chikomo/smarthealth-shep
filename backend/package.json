{
  "name": "smarthealth-api",
  "version": "1.0.0",
  "private": true,
  "description": "SmartHealth REST API — patient app backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "vitest run tests/security.test.ts",
    "test:search": "vitest run tests/search.test.ts",
    "test:audit": "vitest run tests/audit.test.ts",
    "security:owasp": "tsx scripts/owasp-check.ts",
    "lint": "tsc --noEmit",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "import:providers": "tsx src/import/import_practitioners.ts",
    "import:dual": "tsx src/import/import_dual_registry.ts",
    "import:emails": "tsx src/import/import_practitioner_emails.ts",
    "import:wipe": "tsx src/import/wipe_import_data.ts",
    "import:diff": "tsx src/import/registry_diff.ts",
    "import:link": "tsx src/import/link_all.ts",
    "fix:addresses": "tsx src/import/fix_facility_addresses.ts",
    "geocode:facilities": "tsx src/import/geocode_facilities.ts",
    "geocode:import-csv": "tsx src/import/import_geocode_csv.ts",
    "audit:geocode": "tsx src/import/audit_geocode.ts",
    "db:migrate:geocode-quality": "tsx src/import/apply_geocode_migration.ts",
    "classify:facilities": "tsx src/import/classify_facilities.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.2",
    "@sentry/node": "^9.30.0",
    "dotenv": "^16.5.0",
    "fast-levenshtein": "^3.0.0",
    "fastify": "^5.3.3",
    "fastify-type-provider-zod": "^4.0.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.0",
    "tsx": "^4.19.4",
    "xlsx": "^0.18.5",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/fast-levenshtein": "^0.0.4",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.2",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
